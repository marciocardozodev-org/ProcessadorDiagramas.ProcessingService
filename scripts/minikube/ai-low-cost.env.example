# Copie este arquivo para um .env local e ajuste os valores antes do deploy.
# Exemplo:
#   cp scripts/minikube/ai-low-cost.env.example .env.ai
#   set -a && source .env.ai && set +a

AIPROVIDER__ENABLED=true
AIPROVIDER__PROVIDER=OpenAICompatible
AIPROVIDER__BASEURL=https://api.openai.com/
AIPROVIDER__APIKEY=
AIPROVIDER__MODEL=gpt-4o-mini
AIPROVIDER__TEMPERATURE=0.2
AIPROVIDER__MAXTOKENS=500
AIPROVIDER__MAXINPUTCHARACTERS=12000
AIPROVIDER__TIMEOUTSECONDS=60
